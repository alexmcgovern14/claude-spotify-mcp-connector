{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "spotify-mcp",
	"main": "src/index.ts",
	"compatibility_date": "2025-03-10",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"migrations": [
		{
			"new_sqlite_classes": [
				"SpotifyMCP"
			],
			"tag": "v1"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"class_name": "SpotifyMCP",
				"name": "MCP_OBJECT"
			}
		]
	},
	"kv_namespaces": [
		{
			"binding": "OAUTH_KV",
			"id": "e9a5a809ed8f4ae2ab331ce31fd17753"
		}
	],
	"observability": {
		"enabled": true
	}
}